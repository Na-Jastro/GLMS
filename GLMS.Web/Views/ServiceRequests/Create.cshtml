@model GLMS.Core.Models.ServiceRequest

<div class="max-w-2xl mx-auto">

    <h1 class="text-2xl font-semibold mb-6">
        Create Service Request
    </h1>

    <form asp-action="Create"
          method="post"
          class="bg-white p-6 rounded-xl shadow-sm border space-y-5">

        @Html.AntiForgeryToken()

        <!-- ERROR MESSAGE -->
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="bg-red-100 border border-red-300 text-red-700 px-4 py-3 rounded text-sm">
                @Html.ValidationSummary(false)
            </div>
        }

        <!-- CONTRACT -->
        <div>

            <label class="block text-sm font-medium text-gray-700 mb-1">
                Contract
            </label>

            <select asp-for="ContractId"
                    asp-items="ViewBag.Contracts"
                    class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none">

                <option value="">Select Contract</option>

            </select>

            <span asp-validation-for="ContractId"
                  class="text-red-600 text-sm"></span>

        </div>

        <!-- TITLE -->
        <div>

            <label class="block text-sm font-medium text-gray-700 mb-1">
                Title
            </label>

            <input asp-for="Title"
                   class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none" />

            <span asp-validation-for="Title"
                  class="text-red-600 text-sm"></span>

        </div>

        <!-- DESCRIPTION -->
        <div>

            <label class="block text-sm font-medium text-gray-700 mb-1">
                Description
            </label>

<textarea asp-for="Description"
          rows="4"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none"></textarea>

            <span asp-validation-for="Description"
                  class="text-red-600 text-sm"></span>

        </div>

        <!-- USD AMOUNT -->
        <div>

            <label class="block text-sm font-medium text-gray-700 mb-1">
                Amount (USD)
            </label>

            <div class="flex gap-2">

                <input asp-for="AmountUSD"
                       id="usdAmount"
                       class="w-full border border-gray-300 rounded-lg px-3 py-2 focus:ring-2 focus:ring-blue-500 focus:outline-none" />

                <button type="button"
                        id="convertBtn"
                        class="bg-gray-800 text-white px-4 rounded-lg text-sm hover:bg-black">
                    Convert
                </button>

            </div>

            <span asp-validation-for="AmountUSD"
                  class="text-red-600 text-sm"></span>

        </div>

        <!-- ZAR VALUE -->

        <div>

            <label class="block text-sm font-medium text-gray-700 mb-1">
                Local Cost (ZAR)
            </label>

            <input asp-for="LocalCostZAR"
                   readonly
                   class="w-full bg-gray-100 border border-gray-300 rounded-lg px-3 py-2" />

        </div>

        <!-- BUTTONS -->
        <div class="pt-2 flex gap-3">

            <button type="submit"
                    class="bg-blue-600 text-white px-5 py-2.5 rounded-lg hover:bg-blue-700 text-sm font-medium transition">
                Create Request
            </button>

            <a asp-action="Index"
               class="text-gray-600 hover:text-blue-600 text-sm pt-2">
                Cancel
            </a>

        </div>

    </form>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>

        document.getElementById("convertBtn").addEventListener("click", async function () {

            const usd = document.getElementById("usdAmount").value;

            if (!usd) {
                alert("Enter USD amount first");
                return;
            }

            const response = await fetch(`/ServiceRequests/ConvertUsdToZar?usd=${usd}`);

            const zar = await response.json();

            document.getElementById("LocalCostZAR").value = zar.toFixed(2);

        });

    </script>
}