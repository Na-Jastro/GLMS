@model IEnumerable<GLMS.Core.Models.ServiceRequest>

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-semibold">Service Requests</h1>

    <a asp-action="Create"
       class="bg-blue-600 text-white px-5 py-2.5 rounded-lg hover:bg-blue-700 text-sm font-medium">
        + New Request
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="bg-green-100 border border-green-300 text-green-700 px-4 py-3 rounded mb-6">
        @TempData["Success"]
    </div>
}

<div class="bg-white rounded-xl shadow-sm border overflow-hidden">

    <table class="w-full text-sm">

        <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
            <tr>
                <th class="p-4 text-left">Title</th>
                <th class="p-4 text-left">Contract Client</th>
                <th class="p-4 text-left">Status</th>
                <th class="p-4 text-left">Created</th>
                <th class="p-4 text-right">Actions</th>
            </tr>
        </thead>

        <tbody>

            @if (!Model.Any())
            {
                <tr>
                    <td colspan="5" class="text-center p-6 text-gray-500">
                        No service requests found.
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    <tr class="border-t hover:bg-gray-50">

                        <td class="p-4 font-medium">
                            @item.Title
                        </td>

                        <td class="p-4">
                            @(item.Contract?.Client?.Name ?? "N/A")
                        </td>

                        <td class="p-4">

                            <span class="inline-block px-3 py-1 rounded-full text-xs font-medium
            @(item.Status == "Open" ? "bg-green-100 text-green-700" :
                                        item.Status == "Closed" ? "bg-red-100 text-red-700" :
                                        "bg-gray-100 text-gray-700")">
                                @item.Status
                            </span>

                        </td>

                        <td class="p-4">
                            @item.CreatedDate.ToString("dd MMM yyyy")
                        </td>

                        <td class="p-4 text-right">

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="text-blue-600 hover:underline">
                                View
                            </a>

                        </td>

                    </tr>
                }
            }

        </tbody>

    </table>

</div>