@model GLMS.Core.Models.Client

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-semibold">Create Client</h1>
    <a asp-action="Index" class="text-sm text-gray-600 hover:text-blue-600">
        ← Back
    </a>
</div>

<form asp-action="Create" method="post"
      class="bg-white p-8 rounded-xl shadow-sm border max-w-xl space-y-6">

    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="text-red-600 text-sm"></div>

    <div>
        <label asp-for="Name" class="block text-sm font-medium mb-2"></label>
        <input asp-for="Name" class="w-full border rounded-lg p-3" />
        <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
    </div>

    <div>
        <label asp-for="ContactDetails" class="block text-sm font-medium mb-2"></label>
        <input asp-for="ContactDetails" class="w-full border rounded-lg p-3" />
    </div>

    <div>
        <label asp-for="Region" class="block text-sm font-medium mb-2"></label>
        <input asp-for="Region" class="w-full border rounded-lg p-3" />
    </div>

    <div class="flex gap-4">
        <button class="bg-blue-600 text-white px-6 py-3 rounded-lg hover:bg-blue-700">
            Save
        </button>
        <a asp-action="Index" class="bg-gray-200 px-6 py-3 rounded-lg hover:bg-gray-300">
            Cancel
        </a>
    </div>

</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}