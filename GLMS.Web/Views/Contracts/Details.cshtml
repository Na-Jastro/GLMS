@using GLMS.Core.Models
@model GLMS.Core.Models.Contract

<h1 class="text-2xl font-semibold mb-6">
    Contract Details
</h1>

<div class="bg-white p-6 rounded-xl shadow-sm border mb-8 space-y-4">

    <div>
        <span class="text-sm text-gray-500">Client</span>
        <p class="font-medium">@Model.Client?.Name</p>
    </div>

    <div>
        <span class="text-sm text-gray-500">Start Date</span>
        <p>@Model.StartDate.ToShortDateString()</p>
    </div>

    <div>
        <span class="text-sm text-gray-500">End Date</span>
        <p>@Model.EndDate.ToShortDateString()</p>
    </div>

    <div>
        <span class="text-sm text-gray-500">Status</span>

        <span class="px-3 py-1 rounded-full text-xs font-medium
@(Model.Status == ContractStatus.Active ? "bg-green-100 text-green-700" :
              Model.Status == ContractStatus.Expired ? "bg-red-100 text-red-700" :
              Model.Status == ContractStatus.OnHold ? "bg-yellow-100 text-yellow-700" :
              "bg-gray-100 text-gray-700")">

            @Model.Status

        </span>

    </div>

    <div>
        <span class="text-sm text-gray-500">SLA</span>
        <p>@Model.ServiceLevel</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
    {
        <div>
            <a asp-action="DownloadAgreement"
               asp-route-id="@Model.Id"
               class="text-blue-600 hover:underline">
                Download Signed Agreement
            </a>
        </div>
    }

</div>

<!-- SERVICE REQUESTS -->

<h2 class="text-xl font-semibold mb-4">
    Service Requests
</h2>

<div class="bg-white rounded-xl shadow-sm border overflow-hidden">

    <table class="w-full text-sm">

        <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
            <tr>
                <th class="p-4 text-left">Title</th>
                <th class="p-4 text-left">Status</th>
                <th class="p-4 text-left">Created</th>
                <th class="p-4 text-right">Actions</th>
            </tr>
        </thead>

        <tbody>

            @if (Model.ServiceRequests == null || !Model.ServiceRequests.Any())
            {
                <tr>
                    <td colspan="4" class="text-center p-6 text-gray-500">
                        No service requests for this contract.
                    </td>
                </tr>
            }
            else
            {
                foreach (var request in Model.ServiceRequests)
                {
                    <tr class="border-t hover:bg-gray-50">

                        <td class="p-4 font-medium">@request.Title</td>

                        <td class="p-4">@request.Status</td>

                        <td class="p-4">@request.CreatedDate.ToShortDateString()</td>

                        <td class="p-4 text-right">

                            <a asp-controller="ServiceRequests"
                               asp-action="Details"
                               asp-route-id="@request.Id"
                               class="text-blue-600 hover:underline">
                                View
                            </a>

                        </td>

                    </tr>
                }
            }

        </tbody>

    </table>

</div>

<div class="mt-6">

    <a asp-controller="ServiceRequests"
       asp-action="Create"
       asp-route-contractId="@Model.Id"
       class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
        Create Service Request
    </a>

</div>