@using GLMS.Core.Models
@model GLMS.Core.Models.Contract

<h1 class="text-2xl font-semibold mb-6">
    Contract Details
</h1>

<div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 mb-8 space-y-5">

    <div>
        <span class="text-sm text-gray-500">Client</span>
        <p class="font-medium text-gray-900">
            @Model.Client?.Name
        </p>
    </div>

    <div>
        <span class="text-sm text-gray-500">Start Date</span>
        <p class="text-gray-800">
            @Model.StartDate.ToShortDateString()
        </p>
    </div>

    <div>
        <span class="text-sm text-gray-500">End Date</span>
        <p class="text-gray-800">
            @Model.EndDate.ToShortDateString()
        </p>
    </div>

    <div>
        <span class="text-sm text-gray-500">Status</span>

        <div class="mt-2">
            <span class="px-3 py-1 rounded-full text-xs font-semibold tracking-wide
                @(Model.Status == ContractStatus.Active ? "bg-green-100 text-green-700" :
                                    Model.Status == ContractStatus.Expired ? "bg-red-100 text-red-700" :
                                    Model.Status == ContractStatus.OnHold ? "bg-yellow-100 text-yellow-700" :
                                    "bg-gray-100 text-gray-700")">

                @Model.Status

            </span>
        </div>

    </div>

    <div>
        <span class="text-sm text-gray-500">SLA</span>
        <p class="text-gray-800">
            @Model.ServiceLevel
        </p>
    </div>

    @if (!string.IsNullOrEmpty(Model.SignedAgreementPath))
    {
        <div>
            <a asp-action="DownloadAgreement"
                   asp-route-id="@Model.Id"
                   class="inline-flex items-center gap-2 text-blue-600 font-medium hover:text-blue-800 transition">

                <i class="fas fa-download"></i>

                Download Signed Agreement

            </a>
        </div>
    }

</div>

<!-- SERVICE REQUESTS -->

<div class="flex items-center justify-between mb-4">

    <h2 class="text-xl font-semibold">
        Service Requests
    </h2>

</div>

<div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">

    <table class="w-full text-sm">

        <thead class="bg-gray-50 text-gray-600 uppercase text-xs">

            <tr>
                <th class="p-4 text-left">Title</th>
                <th class="p-4 text-left">Status</th>
                <th class="p-4 text-left">Created</th>
                <th class="p-4 text-right">Actions</th>
            </tr>

        </thead>

        <tbody>

            @if (Model.ServiceRequests == null || !Model.ServiceRequests.Any())
            {
                <tr>
                    <td colspan="4" class="text-center p-6 text-gray-500">
                        No service requests for this contract.
                    </td>
                </tr>
            }
            else
            {
                foreach (var request in Model.ServiceRequests)
                {
                    <tr class="border-t border-gray-100 hover:bg-gray-50 transition">

                        <td class="p-4 font-medium text-gray-900">
                            @request.Title
                        </td>

                        <td class="p-4 text-gray-700">
                            @request.Status
                        </td>

                        <td class="p-4 text-gray-700">
                            @request.CreatedDate.ToShortDateString()
                        </td>

                        <td class="p-4 text-right">

                            <a asp-controller="ServiceRequests"
                                   asp-action="Details"
                                   asp-route-id="@request.Id"
                                   class="inline-flex items-center gap-2 text-blue-600 font-medium hover:text-blue-800 transition">

                                <i class="fas fa-eye"></i>

                                View

                            </a>

                        </td>

                    </tr>
                }
            }

        </tbody>

    </table>

</div>

<!-- ACTION BUTTONS -->

<div class="mt-8 flex flex-wrap items-center gap-4">

    <a asp-controller="ServiceRequests"
           asp-action="Create"
           asp-route-contractId="@Model.Id"
           class="inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-3 rounded-xl font-medium shadow-sm hover:bg-blue-700 hover:shadow-md transition-all duration-200">

        <i class="fas fa-plus"></i>

        Create Service Request

    </a>

    <a asp-action="Index"
           class="inline-flex items-center gap-2 bg-white border border-gray-300 text-gray-700 px-5 py-3 rounded-xl font-medium shadow-sm hover:bg-gray-50 hover:border-gray-400 transition-all duration-200">

        <i class="fas fa-arrow-left"></i>

        Back to Contracts

    </a>

</div>