<h2 class="text-2xl font-semibold mb-6">Upload Signed Agreement</h2>

<form asp-action="UploadSignedAgreement"
      method="post"
      enctype="multipart/form-data"
      class="bg-white p-6 rounded-lg shadow-md space-y-4">

    <input type="hidden" name="id" value="@ViewBag.ContractId" />

    <div>

        <label class="block text-sm font-medium mb-1">
            Select PDF
        </label>

        <input type="file"
               name="file"
               accept=".pdf"
               class="w-full border p-2 rounded-lg" />

    </div>

    <button type="submit"
            class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700">

        Upload Agreement

    </button>

</form>