@model IEnumerable<GLMS.Core.Models.Contract>
@using GLMS.Core.Models

@if (TempData["Success"] != null)
{
    <div class="bg-green-100 text-green-700 p-3 rounded mb-6">
        @TempData["Success"]
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="bg-red-100 text-red-700 p-3 rounded mb-6">
        @TempData["Error"]
    </div>
}

<div class="flex justify-between items-center mb-8">
    <h1 class="text-2xl font-semibold">Contract Management</h1>

    <a asp-action="Create"
       class="bg-blue-600 text-white px-5 py-2.5 rounded-lg hover:bg-blue-700 text-sm font-medium">
        + New Contract
    </a>
</div>

<!-- Dashboard -->
<div class="grid grid-cols-3 gap-6 mb-8">

    <div class="bg-white p-6 rounded-xl shadow-sm border">
        <p class="text-sm text-gray-500">Total Contracts</p>
        <p class="text-2xl font-semibold mt-2">@ViewBag.Total</p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border">
        <p class="text-sm text-gray-500">Active</p>
        <p class="text-2xl font-semibold mt-2 text-green-600">@ViewBag.Active</p>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-sm border">
        <p class="text-sm text-gray-500">Expired</p>
        <p class="text-2xl font-semibold mt-2 text-red-600">@ViewBag.Expired</p>
    </div>

</div>

<!-- SEARCH FILTER -->
<form method="get"
      asp-action="Index"
      class="bg-white p-4 rounded-xl shadow-sm border mb-6 grid grid-cols-4 gap-4">

    <div>
        <label class="text-sm text-gray-600">Start Date</label>
        <input type="date"
               name="start"
               value="@Context.Request.Query["start"]"
               class="w-full border rounded p-2" />
    </div>

    <div>
        <label class="text-sm text-gray-600">End Date</label>
        <input type="date"
               name="end"
               value="@Context.Request.Query["end"]"
               class="w-full border rounded p-2" />
    </div>

    <div>
        <label class="text-sm text-gray-600">Status</label>

        <select name="status"
                class="w-full border rounded p-2">

            <option value="">All</option>

            @foreach (var s in Enum.GetValues(typeof(ContractStatus)))
            {
                <option value="@s">@s</option>
            }

        </select>

    </div>

    <div class="flex items-end gap-2">

        <button class="bg-blue-600 text-white px-4 py-2 rounded hover:bg-blue-700">
            Search
        </button>

        <a asp-action="Index"
           class="bg-gray-300 px-4 py-2 rounded">
            Reset
        </a>

    </div>

</form>

<!-- CONTRACT TABLE -->
<div class="bg-white rounded-xl shadow-sm border overflow-hidden">

    <table class="w-full table-fixed text-sm">

        <thead class="bg-gray-50 text-gray-600 uppercase text-xs">
            <tr>

                <th class="p-4 text-left w-1/5">Client</th>
                <th class="p-4 text-left w-1/6">Start</th>
                <th class="p-4 text-left w-1/6">End</th>
                <th class="p-4 text-left w-1/6">Status</th>
                <th class="p-4 text-left w-1/6">SLA</th>
                <th class="p-4 text-right w-1/3">Actions</th>

            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr class="border-t hover:bg-gray-50">

                    <td class="p-4 font-medium truncate">@item.Client?.Name</td>

                    <td class="p-4">@item.StartDate.ToShortDateString()</td>

                    <td class="p-4">@item.EndDate.ToShortDateString()</td>

                    <td class="p-4">

                        <span class="px-3 py-1 rounded-full text-xs font-medium
    @(item.Status == ContractStatus.Active ? "bg-green-100 text-green-700" :
                              item.Status == ContractStatus.Expired ? "bg-red-100 text-red-700" :
                              item.Status == ContractStatus.OnHold ? "bg-yellow-100 text-yellow-700" :
                              "bg-gray-100 text-gray-700")">

                            @item.Status

                        </span>

                    </td>

                    <td class="p-4 truncate">@item.ServiceLevel</td>

                    <td class="p-4 text-right">

                        <div class="flex justify-end items-center gap-3 flex-nowrap">

                            <a asp-action="Details"
                               asp-route-id="@item.Id"
                               class="text-blue-600 hover:underline">
                                View
                            </a>

                            <a asp-action="Edit"
                               asp-route-id="@item.Id"
                               class="text-yellow-600 hover:underline">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@item.Id"
                               class="text-red-600 hover:underline">
                                Delete
                            </a>

                            <form asp-action="UploadSignedAgreement"
                                  asp-route-id="@item.Id"
                                  method="post"
                                  enctype="multipart/form-data"
                                  class="inline">

                                <label class="bg-blue-500 text-white px-3 py-1 rounded text-xs cursor-pointer hover:bg-blue-600">

                                    Upload

                                    <input type="file"
                                           name="file"
                                           accept=".pdf"
                                           onchange="this.form.submit()"
                                           class="hidden" />

                                </label>

                            </form>

                            @if (!string.IsNullOrEmpty(item.SignedAgreementPath))
                            {
                                <a asp-action="DownloadAgreement"
                                   asp-route-id="@item.Id"
                                   class="text-green-600 hover:underline">
                                    Download
                                </a>
                            }

                        </div>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>